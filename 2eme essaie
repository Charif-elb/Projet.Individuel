#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_ILI9341.h>

// 1. DEFINITIONS DES PINS
#define TFT_CS 15
#define TFT_DC 2
#define TFT_RST 4

#define BTN_RIGHT 27
#define BTN_LEFT 25
#define BTN_UP 33
#define BTN_DOWN 26
#define BUZZER 17

Adafruit_ILI9341 tft(TFT_CS, TFT_DC, TFT_RST);

// 2. LES VARIABLES GLOBALES
enum State { MENU, SETTINGS, GAME, WIN, GAMEOVER };
State state = MENU;

bool soundOn = true;
int level = 1;
int vies = 3; 
int menuSelection = 0; 
int choiceSelection = 0; 

#define VIDE 0
#define MUR 1
#define FLAG 2
#define SOL 3
#define MONSTER 4

#define COLS 16
#define ROWS 10
#define CELL 20
#define HUD_H 40

