// Dessiner une case selon son type
void drawCell(int c,int r){
 uint8_t t=getCell(r,c);

 if (t == MONSTER) {
   drawMonsterSprite(c*CELL, r*CELL+HUD_H);
   return;
 }

 // choisir couleur selon type
 uint16_t col =
   (t==MUR)?ILI9341_WHITE :
   (t==FLAG)?ILI9341_YELLOW :
   (t==SOL)?ILI9341_GREEN :
             ILI9341_BLUE;

 tft.fillRect(c*CELL,r*CELL+HUD_H,CELL,CELL,col);
}

// Dessine toute la carte
void drawMap(){
 for(int r=0;r<ROWS;r++)
   for(int c=0;c<COLS;c++)
     drawCell(c,r);
}

// Dessine le joueur
void drawPlayer(){
 tft.fillRect(playerCol*CELL+3,playerRow*CELL+HUD_H+3,14,14,ILI9341_RED);
}


