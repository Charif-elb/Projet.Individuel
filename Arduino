// ACCES AUX CASES

// Lire une case selon le niveau
uint8_t getCell(int r,int c){
 if(level==1) return niveau1[r][c];
 if(level==2) return niveau2[r][c];
 return niveau3[r][c];
}

// Modifier une case (seulement niveaux modifiables)
void setCell(int r, int c, uint8_t val){
 if(level==2) niveau2[r][c] = val;
 if(level==3) niveau3[r][c] = val;
}


// IA DES MONSTRES (niveau 3)

void updateMonsters() {
 if(level != 3) return; // uniquement niveau 3

 // directions possibles (haut, bas, gauche, droite)
 int dRow[] = {-1, 1, 0, 0};
 int dCol[] = {0, 0, -1, 1};

 for(int i = 0; i < 2; i++) {


   setCell(monstres[i].row, monstres[i].col, VIDE);
   drawCell(monstres[i].col, monstres[i].row);

   int nRow = monstres[i].row;
   int nCol = monstres[i].col;
   bool bouge = false;

   // 70% de chance de poursuivre le joueur
   if(random(0, 100) < 70) {

     // direction vers le joueur
     int cibleRowDir = (playerRow > monstres[i].row) ? 1 :
                       (playerRow < monstres[i].row) ? -1 : 0;

     int cibleColDir = (playerCol > monstres[i].col) ? 1 :
                       (playerCol < monstres[i].col) ? -1 : 0;

     // déplacement prioritaire
     if(abs(playerRow - monstres[i].row) > abs(playerCol - monstres[i].col) && cibleRowDir != 0) {
       uint8_t c = getCell(monstres[i].row + cibleRowDir, monstres[i].col);

       if(c == VIDE || (monstres[i].row + cibleRowDir == playerRow && monstres[i].col == playerCol)) {
         nRow = monstres[i].row + cibleRowDir;
         bouge = true;
       }
     } 
     else if(cibleColDir != 0) {
       uint8_t c = getCell(monstres[i].row, monstres[i].col + cibleColDir);

       if(c == VIDE || (monstres[i].row == playerRow && monstres[i].col + cibleColDir == playerCol)) {
         nCol = monstres[i].col + cibleColDir;
         bouge = true;
       }
     }
   }


   // déplacement aléatoire
   if(!bouge) {
     for(int essai = 0; essai < 10; essai++) {
       int dir = random(0, 4);
       int testRow = monstres[i].row + dRow[dir];
       int testCol = monstres[i].col + dCol[dir];

       uint8_t cible = getCell(testRow, testCol);

       if(cible == VIDE || (testRow == playerRow && testCol == playerCol)) {
         nRow = testRow;
         nCol = testCol;
         break;
       }
     }
   }

   // appliquer déplacement
   monstres[i].row = nRow;
   monstres[i].col = nCol;

   setCell(monstres[i].row, monstres[i].col, MONSTER);
   drawCell(monstres[i].col, monstres[i].row);

   // collision joueur
   if(playerCol == monstres[i].col && playerRow == monstres[i].row){
      vies = 0;
      drawHUD();
      state = GAMEOVER;
      choiceSelection = 0;
      drawGameOverScreen();
      return; 
   }
 }
}


