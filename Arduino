// INITIALISATION PARTIE

void startGame(){
 playerCol=1;
 playerRow=8;
 steps=0;
 vies=3;

 // monstre niveau 2
 if(level == 2)
   niveau2[4][11] = MONSTER;

 // reset monstres niveau 3
 for(int r=0; r<ROWS; r++)
   for(int c=0; c<COLS; c++)
     if(niveau3[r][c] == MONSTER)
       niveau3[r][c] = VIDE;

 // position initiale monstres
 monstres[0].row = 1;
 monstres[0].col = 13;
 monstres[1].row = 3;
 monstres[1].col = 8;

 if (level == 3) {
   niveau3[monstres[0].row][monstres[0].col] = MONSTER;
   niveau3[monstres[1].row][monstres[1].col] = MONSTER;
 }

 tft.fillScreen(ILI9341_BLUE);
 drawMap();
 drawHUD();
 drawPlayer();
}


